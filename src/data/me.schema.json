{
  "type": "object",
  "required": [
    "personalDetails",
    "about",
    "marquee",
    "companies",
    "education",
    "personalProjects",
    "skills"
  ],
  "properties": {
    "personalDetails": {
      "type": "object",
      "required": [
        "name",
        "role",
        "description",
        "email",
        "phone",
        "currentLocation",
        "linkedin",
        "github",
        "x",
        "leetcode",
        "resumeLink",
        "tagline",
        "status"
      ],
      "properties": {
        "name": {
          "type": "object",
          "required": [
            "first",
            "last"
          ],
          "properties": {
            "first": {
              "type": "string"
            },
            "last": {
              "type": "string"
            }
          }
        },
        "role": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "phone": {
          "type": "object",
          "required": [
            "prefixCode",
            "number"
          ],
          "properties": {
            "prefixCode": {
              "type": "string"
            },
            "number": {
              "type": "string"
            }
          }
        },
        "currentLocation": {
          "type": "object",
          "required": [
            "city",
            "state",
            "country"
          ],
          "properties": {
            "city": {
              "type": "string"
            },
            "state": {
              "type": "string"
            },
            "country": {
              "type": "string"
            }
          }
        },
        "linkedin": {
          "type": "string"
        },
        "github": {
          "type": "string"
        },
        "x": {
          "type": "string"
        },
        "leetcode": {
          "type": "string"
        },
        "resumeLink": {
          "type": "string"
        },
        "tagline": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      }
    },
    "about": {
      "type": "object",
      "required": [
        "statement",
        "body",
        "focus",
        "experienceSummary"
      ],
      "properties": {
        "statement": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "focus": {
          "type": "string"
        },
        "experienceSummary": {
          "type": "string"
        }
      }
    },
    "marquee": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "companies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "company",
          "span",
          "tenure",
          "roles"
        ],
        "properties": {
          "id": {
            "type": "number"
          },
          "company": {
            "type": "string"
          },
          "website": {
            "type": "string",
            "description": "Optional company URL"
          },
          "span": {
            "type": "string",
            "description": "Full range at the company, e.g. 'Jan 2022 - 2025'"
          },
          "tenure": {
            "type": "string",
            "description": "Short label, e.g. 'Current', '3 yrs · 3 roles', 'Internship'"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "title",
                "period",
                "current",
                "description",
                "skills"
              ],
              "properties": {
                "title": {
                  "type": "string"
                },
                "period": {
                  "type": "string"
                },
                "current": {
                  "type": "boolean"
                },
                "description": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "skills": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "institute",
          "duration",
          "degree",
          "courses"
        ],
        "properties": {
          "id": {
            "type": "number"
          },
          "institute": {
            "type": "string"
          },
          "duration": {
            "type": "string"
          },
          "degree": {
            "type": "string"
          },
          "courses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "personalProjects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "links"
        ],
        "properties": {
          "id": {
            "type": "number"
          },
          "name": {
            "type": "string"
          },
          "tag": {
            "type": "string",
            "description": "Short uppercase card label, e.g. 'Web App'"
          },
          "description": {
            "type": "string"
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "url"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                }
              }
            }
          },
          "techUsed": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "skills"
        ],
        "properties": {
          "id": {
            "type": "number"
          },
          "category": {
            "type": "string"
          },
          "skills": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "icon": {
                  "type": "string",
                  "description": "simple-icons slug (https://simpleicons.org)"
                },
                "mono": {
                  "type": "string",
                  "description": "2-3 letter fallback badge when no icon exists"
                }
              }
            }
          }
        }
      }
    }
  }
}
